# ===================================
# Configurações da SDK
# ===================================

# Token de autenticação da API (obrigatório em produção)
API_TOKEN=seu-token-aqui

# URL do servidor de especificação da API (opcional - usa padrão se não definido)
SDK_SPEC_SERVER_URL=https://api.consultasdeveiculos.com/sdk/spec

# URL base da API (opcional - usa padrão se não definido)
# API_BASE_URL=https://api.consultasdeveiculos.com

# Timeout das requisições em ms (opcional - padrão: 30000)
# API_TIMEOUT=30000

# Número máximo de retries (opcional - padrão: 3)
# API_MAX_RETRIES=3
